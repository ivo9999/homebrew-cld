#!/bin/bash

# cld — Claude Code workspace launcher
#
# Usage:
#   cld [repo-path] [branch] [session-name]   Open a project (default: current dir)
#   cld help                                   Show this help message
#   cld ls                                     List active sessions
#   cld status                                 Show detailed session info
#   cld kill [session]                         Kill a session (current if inside tmux)
#   cld attach <session>                       Attach to a session (partial match)
#   cld clean [repo-path] [--all]              Remove worktrees + sessions
#   cld update                                 Update cld and Claude Code
#   cld version                                Show version
#
# Examples:
#   cld                                        Current dir, no worktree
#   cld ~/projects/ja                          Open project
#   cld ~/projects/ja feature/auth             Create worktree + open
#   cld ~/projects/ja feature/auth ja-auth     Custom session name
#   cld help                                   Print usage
#   cld ls                                     Show all sessions
#   cld status                                 Show session details
#   cld kill                                   Kill current session (from inside tmux)
#   cld kill ja-auth                           Kill session 'ja-auth'
#   cld kill ja                                Kill first session matching 'ja'
#   cld attach ja                              Attach to first session matching 'ja'
#   cld clean ~/projects/ja                    Interactive cleanup
#   cld clean ~/projects/ja --all              Remove all worktrees
#   cld update                                 Update cld + Claude Code

CLD_VERSION="0.2.6"

set -e

# ─── Colors ───────────────────────────────────────────────────────────────

if [ -t 1 ]; then
  BOLD="\033[1m"
  DIM="\033[2m"
  GREEN="\033[32m"
  YELLOW="\033[33m"
  RED="\033[31m"
  CYAN="\033[36m"
  RESET="\033[0m"
else
  BOLD="" DIM="" GREEN="" YELLOW="" RED="" CYAN="" RESET=""
fi

# ─── Helpers ────────────────────────────────────────────────────────────────

info()  { printf "${CYAN}%s${RESET}\n" "$1"; }
ok()    { printf "${GREEN}%s${RESET}\n" "$1"; }
warn()  { printf "${YELLOW}%s${RESET}\n" "$1"; }
err()   { printf "${RED}%s${RESET}\n" "$1" >&2; }

sanitize_session_name() {
  echo "$1" | sed 's/[\.:]/-/g'
}

check_deps() {
  if ! command -v tmux &>/dev/null; then
    err "Error: tmux is not installed. Install with: brew install tmux"
    exit 1
  fi
}

check_git_repo() {
  if ! git -C "$1" rev-parse --git-dir &>/dev/null; then
    err "Error: '$1' is not a git repository."
    exit 1
  fi
}

show_help() {
  sed -n '/^# Usage:/,/^[^#]/{ /^#/s/^# \{0,1\}//p; }' "$0"
  echo ""
  sed -n '/^# Examples:/,/^[^#]/{ /^#/s/^# \{0,1\}//p; }' "$0"
}

# Find a tmux session by exact name or partial match
# Sets FOUND_SESSION on success, returns 1 on failure
find_session() {
  local query="$1"
  if tmux has-session -t "$query" 2>/dev/null; then
    FOUND_SESSION="$query"
    return 0
  fi
  FOUND_SESSION=$(tmux ls -F '#{session_name}' 2>/dev/null | grep -i "$query" | head -1)
  [ -n "$FOUND_SESSION" ]
}

# ─── Subcommands ─────────────────────────────────────────────────────────────

check_deps

case "$1" in
help|-h|--help)
  show_help
  exit 0
  ;;
version|-v|--version)
  echo "cld $CLD_VERSION"
  exit 0
  ;;
update)
  info "Updating cld..."
  if brew ls --versions cld &>/dev/null; then
    brew update --quiet
    brew upgrade cld 2>/dev/null && ok "cld updated." || info "cld already up to date."
  else
    curl -fsSL https://raw.githubusercontent.com/ivo9999/homebrew-cld/main/install.sh | bash
  fi
  echo ""
  info "Updating Claude Code..."
  brew upgrade claude-code 2>/dev/null && ok "Claude Code updated." || info "Claude Code already up to date."
  exit 0
  ;;
ls)
  tmux ls 2>/dev/null || warn "No active sessions."
  exit 0
  ;;
status)
  if ! tmux ls &>/dev/null; then
    warn "No active sessions."
    exit 0
  fi
  printf "${BOLD}%-24s %-8s %-44s %s${RESET}\n" "SESSION" "PANES" "DIRECTORY" "CLAUDE?"
  printf "${DIM}%-24s %-8s %-44s %s${RESET}\n" "───────" "─────" "─────────" "───────"
  tmux ls -F '#{session_name}' 2>/dev/null | while read -r sess; do
    PANES=$(tmux list-panes -t "$sess" 2>/dev/null | wc -l | tr -d ' ')
    DIR=$(tmux display-message -t "$sess" -p '#{pane_current_path}' 2>/dev/null)
    CLAUDE_RUNNING="no"
    if tmux list-panes -t "$sess" -F '#{pane_current_command}' 2>/dev/null | grep -qi claude; then
      CLAUDE_RUNNING="${GREEN}yes${RESET}"
    else
      CLAUDE_RUNNING="${DIM}no${RESET}"
    fi
    printf "%-24s %-8s %-44s ${CLAUDE_RUNNING}\n" "$sess" "$PANES" "$DIR"
  done
  exit 0
  ;;
kill)
  if [ -z "$2" ]; then
    if [ -n "$TMUX" ]; then
      CURRENT_SESSION=$(tmux display-message -p '#{session_name}')
      tmux kill-session -t "$CURRENT_SESSION"
    else
      SESSIONS=()
      while IFS= read -r s; do
        [ -n "$s" ] && SESSIONS+=("$s")
      done < <(tmux ls -F '#{session_name}' 2>/dev/null)
      if [ ${#SESSIONS[@]} -eq 0 ]; then
        warn "No active sessions."
        exit 0
      fi
      echo "Active sessions:"
      for i in "${!SESSIONS[@]}"; do
        printf "  ${BOLD}%d)${RESET} %s\n" "$((i + 1))" "${SESSIONS[$i]}"
      done
      echo ""
      read -p "Kill (number, q to quit): " CHOICE
      [ "$CHOICE" = "q" ] && exit 0
      if [[ "$CHOICE" =~ ^[0-9]+$ ]] && [ "$CHOICE" -ge 1 ] && [ "$CHOICE" -le ${#SESSIONS[@]} ]; then
        TARGET="${SESSIONS[$((CHOICE - 1))]}"
        tmux kill-session -t "$TARGET"
        ok "✖ Killed session '$TARGET'"
      else
        err "Invalid choice."
        exit 1
      fi
    fi
  elif find_session "$2"; then
    tmux kill-session -t "$FOUND_SESSION"
    ok "✖ Killed session '$FOUND_SESSION'"
  else
    err "No session matching '$2'."
    tmux ls 2>/dev/null || true
  fi
  exit 0
  ;;
attach)
  if [ -z "$2" ]; then
    err "Usage: cld attach <session>"
    exit 1
  fi
  if find_session "$2"; then
    info "⏭  Attaching to '$FOUND_SESSION'..."
    if [ -n "$TMUX" ]; then
      tmux switch-client -t "$FOUND_SESSION"
    else
      tmux attach -t "$FOUND_SESSION"
    fi
  else
    err "No session matching '$2'."
    tmux ls 2>/dev/null || true
  fi
  exit 0
  ;;
clean)
  REPO_PATH="${2:-.}"
  REPO_PATH=$(realpath "$REPO_PATH")
  check_git_repo "$REPO_PATH"
  REPO_NAME=$(basename "$REPO_PATH")
  WORKTREE_BASE="$(dirname "$REPO_PATH")/${REPO_NAME}-worktrees"

  cd "$REPO_PATH"
  info "🌿 Worktrees for $REPO_NAME:"
  git worktree list
  echo ""

  if [ ! -d "$WORKTREE_BASE" ]; then
    warn "No worktrees to clean."
    exit 0
  fi

  if [ "$3" = "--all" ]; then
    for dir in "$WORKTREE_BASE"/*/; do
      [ ! -d "$dir" ] && continue
      BRANCH_SLUG=$(basename "$dir")
      SESSION=$(sanitize_session_name "${REPO_NAME}-${BRANCH_SLUG}")
      tmux kill-session -t "$SESSION" 2>/dev/null && warn "  ✖ Session: $SESSION"
      git worktree remove "$dir" --force 2>/dev/null || rm -rf "$dir"
      warn "  ✖ Worktree: $BRANCH_SLUG"
    done
    rmdir "$WORKTREE_BASE" 2>/dev/null || true
    git worktree prune
    ok "✅ Done!"
  else
    i=1
    DIRS=()
    for dir in "$WORKTREE_BASE"/*/; do
      [ ! -d "$dir" ] && continue
      DIRS+=("$dir")
      SLUG=$(basename "$dir")
      SESSION=$(sanitize_session_name "${REPO_NAME}-${SLUG}")
      TAG=""
      tmux has-session -t "$SESSION" 2>/dev/null && TAG=" ${GREEN}[tmux]${RESET}"
      printf "  ${BOLD}%d)${RESET} %s%b\n" "$i" "$SLUG" "$TAG"
      i=$((i + 1))
    done
    [ ${#DIRS[@]} -eq 0 ] && warn "Nothing to clean." && exit 0
    echo ""
    read -p "Remove (space-separated numbers, q to quit): " CHOICES
    [ "$CHOICES" = "q" ] && exit 0
    for c in $CHOICES; do
      dir="${DIRS[$((c - 1))]}"
      [ ! -d "$dir" ] && continue
      SLUG=$(basename "$dir")
      SESSION=$(sanitize_session_name "${REPO_NAME}-${SLUG}")
      tmux kill-session -t "$SESSION" 2>/dev/null && warn "  ✖ Session: $SESSION"
      git worktree remove "$dir" --force 2>/dev/null || rm -rf "$dir"
      warn "  ✖ Worktree: $SLUG"
    done
    git worktree prune
    ok "✅ Done!"
  fi
  exit 0
  ;;
esac

# ─── Main: open project ─────────────────────────────────────────────────────

REPO_PATH="${1:-.}"
REPO_PATH=$(realpath "$REPO_PATH")
BRANCH="$2"
CUSTOM_SESSION="$3"
REPO_NAME=$(basename "$REPO_PATH")

# Resolve worktree if branch given
if [ -n "$BRANCH" ]; then
  check_git_repo "$REPO_PATH"
  BRANCH_SLUG=$(echo "$BRANCH" | sed 's/[\/:]/-/g')
  WORKTREE_BASE="$(dirname "$REPO_PATH")/${REPO_NAME}-worktrees"
  WORKTREE_PATH="${WORKTREE_BASE}/${BRANCH_SLUG}"
  SESSION_NAME=$(sanitize_session_name "${CUSTOM_SESSION:-${REPO_NAME}-${BRANCH_SLUG}}")

  if [ -d "$WORKTREE_PATH" ]; then
    info "📂 Worktree exists at $WORKTREE_PATH"
  else
    info "🌿 Creating worktree for '$BRANCH'..."
    mkdir -p "$WORKTREE_BASE"
    cd "$REPO_PATH"
    if git show-ref --verify --quiet "refs/heads/$BRANCH" 2>/dev/null ||
      git show-ref --verify --quiet "refs/remotes/origin/$BRANCH" 2>/dev/null; then
      git worktree add "$WORKTREE_PATH" "$BRANCH"
    else
      info "🆕 New branch '$BRANCH' from HEAD"
      git worktree add -b "$BRANCH" "$WORKTREE_PATH"
    fi
  fi
  WORK_DIR="$WORKTREE_PATH"
else
  SESSION_NAME=$(sanitize_session_name "${CUSTOM_SESSION:-$REPO_NAME}")
  WORK_DIR="$REPO_PATH"
fi

# Attach if session exists
if tmux has-session -t "$SESSION_NAME" 2>/dev/null; then
  info "⏭  Attaching to '$SESSION_NAME'..."
  if [ -n "$TMUX" ]; then
    tmux switch-client -t "$SESSION_NAME"
  else
    tmux attach -t "$SESSION_NAME"
  fi
  exit 0
fi

# Create tmux session
# ┌────────────────────┬──────────┐
# │                    │ Terminal │
# │    Claude Code     │──────────│
# │      (65%)         │ Terminal │
# │                    │  (35%)   │
# └────────────────────┴──────────┘

info "🔄 Updating Claude Code..."
brew upgrade claude-code 2>/dev/null || true

ok "🚀 Starting '$SESSION_NAME' in $WORK_DIR"

tmux new-session -d -s "$SESSION_NAME" -c "$WORK_DIR" -x "$(tput cols)" -y "$(tput lines)"
tmux rename-window -t "$SESSION_NAME" "dev"
tmux set-option -t "$SESSION_NAME" allow-rename off
tmux split-window -h -t "$SESSION_NAME" -c "$WORK_DIR" -p 35
tmux split-window -v -t "$SESSION_NAME" -c "$WORK_DIR"
tmux set-option -t "$SESSION_NAME" mouse on
tmux set-option -t "$SESSION_NAME" history-limit 50000
tmux set-option -t "$SESSION_NAME" mode-keys vi
tmux select-pane -t "$SESSION_NAME:dev.0" -T "claude"
tmux select-pane -t "$SESSION_NAME:dev.1" -T "term"
tmux select-pane -t "$SESSION_NAME:dev.2" -T "term"
tmux set-option -t "$SESSION_NAME" pane-border-status top
tmux set-option -t "$SESSION_NAME" pane-border-format " #{pane_title} "
tmux send-keys -t "$SESSION_NAME:dev.0" "claude --dangerously-skip-permissions" Enter
tmux select-pane -t "$SESSION_NAME:dev.0"
if [ -n "$TMUX" ]; then
  tmux switch-client -t "$SESSION_NAME"
else
  tmux attach -t "$SESSION_NAME"
fi
